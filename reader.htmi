<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>阅读 · Arseeya</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: #0f0c1f;
            color: #e0e0e0;
            padding: 1rem;
            min-height: 100vh;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
        }
        .back-home {
            display: inline-block;
            background: #333;
            color: white;
            padding: 0.5rem 1.2rem;
            border-radius: 2rem;
            text-decoration: none;
            margin-bottom: 1rem;
            font-size: 0.9rem;
        }
        .chapter-list {
            margin-top: 1rem;
        }
        .chapter-item {
            background: rgba(255,255,255,0.05);
            border-radius: 1rem;
            padding: 1rem;
            margin-bottom: 0.8rem;
            cursor: pointer;
            transition: 0.2s;
        }
        .chapter-item:hover {
            background: rgba(255,255,255,0.12);
        }
        .content-view {
            background: rgba(0,0,0,0.3);
            padding: 1.8rem;
            border-radius: 1.5rem;
            line-height: 1.8;
        }
        .font-controls {
            display: flex;
            gap: 0.8rem;
            justify-content: flex-end;
            margin: 1rem 0;
        }
        .font-controls button {
            background: #e94560;
            border: none;
            color: white;
            padding: 0.3rem 0.8rem;
            border-radius: 2rem;
            cursor: pointer;
        }
        .nav-buttons {
            display: flex;
            justify-content: space-between;
            margin-top: 1.5rem;
        }
        .nav-btn {
            background: #e94560;
            border: none;
            color: white;
            padding: 0.5rem 1.2rem;
            border-radius: 2rem;
            cursor: pointer;
        }
        .back-chapter {
            background: #333;
            margin-bottom: 1rem;
            display: inline-block;
            padding: 0.5rem 1.2rem;
            border-radius: 2rem;
            cursor: pointer;
        }
        h1 {
            font-size: 1.8rem;
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>
<div class="container" id="app">
    <a href="index.html" class="back-home">← 返回首页</a>
    <div id="dynamicView">加载中...</div>
</div>

<script>
    let catalogData = null;
    let currentBook = null;
    let currentChapters = [];
    let currentChapterIndex = -1;
    let currentContent = '';
    let currentTitle = '';
    let fontSize = 18;

    async function loadCatalog() {
        const res = await fetch('catalog.json');
        const data = await res.json();
        catalogData = data;
        return data;
    }

    function getBookFromUrl() {
        const params = new URLSearchParams(window.location.search);
        return params.get('book');
    }

    function saveProgress(bookName, chapterIdx) {
        localStorage.setItem('arseeya_reading', JSON.stringify({ book: bookName, idx: chapterIdx }));
    }

    function loadProgress(bookName) {
        try {
            const saved = JSON.parse(localStorage.getItem('arseeya_reading'));
            if(saved && saved.book === bookName && typeof saved.idx === 'number') return saved.idx;
        } catch(e) {}
        return -1;
    }

    async function loadChapterContent(bookFolder, chapterName, idx) {
        const url = `novels/${encodeURIComponent(bookFolder)}/${encodeURIComponent(chapterName)}.txt`;
        try {
            const res = await fetch(url);
            if(!res.ok) throw new Error();
            const text = await res.text();
            const lines = text.split('\n');
            const title = lines[0].trim() || chapterName;
            const content = lines.slice(1).join('\n').trim() || '暂无正文内容';
            currentTitle = title;
            currentContent = content.replace(/[&<>]/g, function(m) {
                if(m === '&') return '&amp;';
                if(m === '<') return '&lt;';
                if(m === '>') return '&gt;';
                return m;
            }).replace(/\n/g, '<br>');
            currentChapterIndex = idx;
            saveProgress(currentBook.name, idx);
            renderContent();
        } catch(e) {
            currentTitle = '加载失败';
            currentContent = '无法读取章节内容，请确认文件存在。';
            renderContent();
        }
    }

    function renderContent() {
        const viewDiv = document.getElementById('dynamicView');
        viewDiv.innerHTML = `
            <div>
                <button class="back-chapter" id="backToListBtn">← 章节列表</button>
                <div class="font-controls">
                    <button id="fontMinus">A-</button>
                    <button id="fontPlus">A+</button>
                </div>
            </div>
            <div class="content-view" id="contentView" style="font-size:${fontSize}px">
                <h2>${currentTitle}</h2>
                <div>${currentContent}</div>
            </div>
            <div class="nav-buttons">
                <button class="nav-btn" id="prevBtn">上一章</button>
                <button class="nav-btn" id="nextBtn">下一章</button>
            </div>
        `;

        document.getElementById('backToListBtn').addEventListener('click', () => renderChapterList());
        document.getElementById('fontMinus').addEventListener('click', () => {
            fontSize = Math.max(14, fontSize - 2);
            document.getElementById('contentView').style.fontSize = fontSize + 'px';
        });
        document.getElementById('fontPlus').addEventListener('click', () => {
            fontSize = Math.min(28, fontSize + 2);
            document.getElementById('contentView').style.fontSize = fontSize + 'px';
        });
        document.getElementById('prevBtn').addEventListener('click', () => {
            if(currentChapterIndex > 0) loadChapterContent(currentBook.folder, currentChapters[currentChapterIndex-1], currentChapterIndex-1);
        });
        document.getElementById('nextBtn').addEventListener('click', () => {
            if(currentChapterIndex < currentChapters.length-1) loadChapterContent(currentBook.folder, currentChapters[currentChapterIndex+1], currentChapterIndex+1);
        });
    }

    function renderChapterList() {
        const viewDiv = document.getElementById('dynamicView');
        let html = `<h1>📖 ${currentBook.name}</h1><div class="chapter-list">`;
        currentChapters.forEach((ch, i) => {
            html += `<div class="chapter-item" data-idx="${i}">📄 ${ch}</div>`;
        });
        html += `</div>`;
        viewDiv.innerHTML = html;
        document.querySelectorAll('.chapter-item').forEach(el => {
            el.addEventListener('click', () => {
                const idx = parseInt(el.getAttribute('data-idx'));
                loadChapterContent(currentBook.folder, currentChapters[idx], idx);
            });
        });
    }

    (async () => {
        await loadCatalog();
        const bookName = getBookFromUrl();
        if(!bookName) {
            document.getElementById('dynamicView').innerHTML = '<p>未指定书籍，请返回首页选择。</p>';
            return;
        }
        const book = catalogData.books.find(b => b.name === bookName);
        if(!book) {
            document.getElementById('dynamicView').innerHTML = '<p>书籍不存在。</p>';
            return;
        }
        currentBook = book;
        currentChapters = book.chapters;
        const savedIdx = loadProgress(bookName);
        if(savedIdx >= 0 && savedIdx < currentChapters.length) {
            if(confirm('是否继续上次阅读进度？')) {
                await loadChapterContent(book.folder, currentChapters[savedIdx], savedIdx);
                return;
            }
        }
        renderChapterList();
    })();
</script>
</body>
</html>