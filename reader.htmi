<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>读者阅读区 - Arseeya</title>
    <style>
        body {
            font-family: system-ui, sans-serif;
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
            background: #1a1a2e;
            color: #eee;
        }
        h1 {
            color: #e94560;
            text-align: center;
        }
        .book-list {
            display: flex;
            flex-wrap: wrap;
            gap: 1.5rem;
            margin-top: 2rem;
        }
        .book-card {
            background: #16213e;
            border-radius: 1rem;
            padding: 1.5rem;
            flex: 1;
            min-width: 200px;
            cursor: pointer;
            transition: transform 0.2s;
            text-align: center;
        }
        .book-card:hover {
            transform: scale(1.02);
            background: #1e2a4a;
        }
        .book-title {
            font-size: 1.5rem;
            font-weight: bold;
            color: #e94560;
        }
        .book-count {
            margin-top: 0.5rem;
            font-size: 0.9rem;
            color: #888;
        }
        .back-btn {
            background: #333;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            display: inline-block;
            margin-bottom: 1rem;
            cursor: pointer;
        }
        .chapter-list {
            margin-top: 1rem;
        }
        .chapter-item {
            background: #0f0f1a;
            padding: 1rem;
            margin: 0.5rem 0;
            border-radius: 0.5rem;
            cursor: pointer;
        }
        .chapter-item:hover {
            background: #1a1a2e;
        }
        .content-view {
            background: #16213e;
            padding: 2rem;
            border-radius: 1rem;
            line-height: 1.8;
        }
        .content-view h2 {
            color: #e94560;
        }
        button {
            background: #e94560;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            color: white;
            cursor: pointer;
        }
        .popup {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 100;
        }
        .popup-content {
            background: #16213e;
            padding: 2rem;
            border-radius: 1rem;
            max-width: 300px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div id="app"></div>

    <script>
        // 一次性欢迎弹窗
        if (!localStorage.getItem("welcome_shown")) {
            localStorage.setItem("welcome_shown", "true");
            setTimeout(() => {
                const popup = document.createElement("div");
                popup.className = "popup";
                popup.innerHTML = `
                    <div class="popup-content">
                        <h2>📖 欢迎光临</h2>
                        <p>这里是 Arseeya 的小说阅读区</p>
                        <p>选择书籍开始阅读~</p>
                        <button onclick="this.parentElement.parentElement.remove()">开始阅读</button>
                    </div>
                `;
                document.body.appendChild(popup);
            }, 100);
        }

        // 书籍配置
        const BOOKS = [
            { name: "听潮事记", folder: "听潮事记" },
            { name: "听潮事记番外集", folder: "听潮事记番外集" }
        ];

        let currentView = "books"; // books, chapters, content
        let currentBook = null;
        let currentChapters = [];
        let currentContent = null;
        let currentChapterName = "";

        async function fetchChapters(folder) {
            try {
                const response = await fetch(`https://api.github.com/repos/Arseeya/arseeya.github.io/contents/novels/${encodeURIComponent(folder)}`);
                if (response.ok) {
                    const files = await response.json();
                    return files.filter(f => f.name.endsWith('.txt')).sort((a,b) => a.name.localeCompare(b.name));
                }
                return [];
            } catch(e) {
                return [];
            }
        }

        async function fetchContent(path) {
            try {
                const response = await fetch(`https://raw.githubusercontent.com/Arseeya/arseeya.github.io/main/${path}`);
                const text = await response.text();
                const lines = text.split('\n');
                const title = lines[0].trim();
                const content = lines.slice(1).join('\n').trim();
                return { title, content };
            } catch(e) {
                return { title: "加载失败", content: "无法读取内容" };
            }
        }

        async function render() {
            const app = document.getElementById("app");
            
            if (currentView === "books") {
                app.innerHTML = `
                    <h1>📚 Arseeya 的小说屋</h1>
                    <div class="book-list">
                        ${BOOKS.map(book => `
                            <div class="book-card" onclick="selectBook('${book.folder}', '${book.name}')">
                                <div class="book-title">${book.name}</div>
                            </div>
                        `).join('')}
                    </div>
                `;
            } else if (currentView === "chapters") {
                app.innerHTML = `
                    <div class="back-btn" onclick="goBack()">← 返回书库</div>
                    <h1>📖 ${currentBook}</h1>
                    <div class="chapter-list" id="chapterList">加载中...</div>
                `;
                const chapters = await fetchChapters(currentBookFolder);
                currentChapters = chapters;
                const chapterList = document.getElementById("chapterList");
                if (chapters.length === 0) {
                    chapterList.innerHTML = '<div>暂无章节，作者正在努力更新中~</div>';
                } else {
                    chapterList.innerHTML = chapters.map(ch => `
                        <div class="chapter-item" onclick="readChapter('${ch.path}')">
                            ${ch.name.replace('.txt', '')}
                        </div>
                    `).join('');
                }
            } else if (currentView === "content") {
                app.innerHTML = `
                    <div class="back-btn" onclick="goBack()">← 返回目录</div>
                    <div class="content-view">
                        <h2>${currentChapterName}</h2>
                        <div>${currentContent.replace(/\n/g, '<br>')}</div>
                    </div>
                `;
            }
        }

        let currentBookFolder = "";

        window.selectBook = async function(folder, name) {
            currentBookFolder = folder;
            currentBook = name;
            currentView = "chapters";
            render();
        }

        window.readChapter = async function(path) {
            const { title, content } = await fetchContent(path);
            currentChapterName = title;
            currentContent = content;
            currentView = "content";
            render();
        }

        window.goBack = function() {
            if (currentView === "chapters") {
                currentView = "books";
                currentBook = null;
                currentBookFolder = "";
                render();
            } else if (currentView === "content") {
                currentView = "chapters";
                render();
            }
        }

        render();
    </script>
</body>
</html>