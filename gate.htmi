<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>权限验证 · Arseeya</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #0f0c1f, #1a1a2e);
            color: #eee;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .gate-card {
            max-width: 450px;
            width: 100%;
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(10px);
            border-radius: 2rem;
            padding: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
            border: 1px solid rgba(255,255,255,0.1);
        }
        h1 {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, #e94560, #667eea);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-align: center;
        }
        .subtitle {
            text-align: center;
            color: #aaa;
            font-size: 0.8rem;
            margin-bottom: 2rem;
        }
        .input-group {
            margin-bottom: 1.5rem;
        }
        label {
            display: block;
            margin-bottom: 0.5rem;
            color: #ddd;
            font-size: 0.9rem;
        }
        input {
            width: 100%;
            padding: 0.8rem 1rem;
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 1rem;
            color: #eee;
            font-size: 1rem;
            transition: 0.2s;
        }
        input:focus {
            outline: none;
            border-color: #e94560;
            background: rgba(0,0,0,0.5);
        }
        .btn {
            width: 100%;
            background: #e94560;
            color: white;
            padding: 0.8rem;
            border-radius: 2rem;
            font-size: 1rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: 0.2s;
            margin-top: 0.5rem;
        }
        .btn:hover {
            background: #c5314b;
            transform: scale(1.02);
        }
        .back-link {
            display: block;
            text-align: center;
            margin-top: 1.5rem;
            color: #aaa;
            text-decoration: none;
            font-size: 0.85rem;
        }
        .back-link:hover {
            color: #e94560;
        }
        .error-msg {
            background: rgba(233,69,96,0.2);
            border: 1px solid #e94560;
            border-radius: 0.8rem;
            padding: 0.8rem;
            margin-bottom: 1rem;
            text-align: center;
            font-size: 0.85rem;
            color: #e94560;
        }
        footer {
            margin-top: 1.5rem;
            text-align: center;
            font-size: 0.7rem;
            color: #666;
        }
    </style>
</head>
<body>
<div class="gate-card">
    <h1>🔐 权限验证</h1>
    <div class="subtitle">请输入访问凭证</div>

    <div id="errorMsg" class="error-msg" style="display: none;"></div>

    <div class="input-group">
        <label>📋 界面代码</label>
        <input type="text" id="pageCode" placeholder="请输入" autocomplete="off">
    </div>

    <div class="input-group">
        <label>🔑 密码</label>
        <input type="password" id="password" placeholder="请输入" autocomplete="off">
    </div>

    <button class="btn" id="submitBtn">✓ 验证</button>

    <a href="index.html" class="back-link">← 返回首页</a>

    <footer>© Arseeya. All Rights Reserved</footer>
</div>

<script>
    // ========== 界面代码 + 密码 → 目标页面映射 ==========
    const ACCESS_MAP = {
        "xhyz": {
            password: "2020458624xhy",
            target: "xhyz.html"
        }
        // 以后添加更多：
        // "code2": { password: "pass2", target: "page2.html" }
    };

    function showError(message) {
        const errorDiv = document.getElementById('errorMsg');
        errorDiv.textContent = message;
        errorDiv.style.display = 'block';
        setTimeout(() => {
            errorDiv.style.display = 'none';
        }, 3000);
    }

    function verifyAndRedirect() {
        const pageCode = document.getElementById('pageCode').value.trim();
        const password = document.getElementById('password').value.trim();

        if (!pageCode || !password) {
            showError('请填写界面代码和密码');
            return;
        }

        const entry = ACCESS_MAP[pageCode];
        if (!entry || password !== entry.password) {
            showError('界面代码或密码错误');
            return;
        }

        // 验证通过，跳转到对应界面（不告诉用户去哪里）
        window.location.href = entry.target;
    }

    document.getElementById('submitBtn').addEventListener('click', verifyAndRedirect);
    document.getElementById('password').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') verifyAndRedirect();
    });
    document.getElementById('pageCode').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') document.getElementById('password').focus();
    });
</script>
</body>
  </html>
