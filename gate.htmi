<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>权限验证 · Arseeya</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #0f0c1f, #1a1a2e);
            color: #eee;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .gate-card {
            max-width: 500px;
            width: 100%;
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(10px);
            border-radius: 2rem;
            padding: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
            border: 1px solid rgba(255,255,255,0.1);
        }
        h1 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, #e94560, #667eea);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-align: center;
        }
        .subtitle {
            text-align: center;
            color: #aaa;
            font-size: 0.85rem;
            margin-bottom: 2rem;
        }
        .input-group {
            margin-bottom: 1.5rem;
        }
        label {
            display: block;
            margin-bottom: 0.5rem;
            color: #ddd;
            font-size: 0.9rem;
        }
        input {
            width: 100%;
            padding: 0.8rem 1rem;
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 1rem;
            color: #eee;
            font-size: 1rem;
            transition: 0.2s;
        }
        input:focus {
            outline: none;
            border-color: #e94560;
            background: rgba(0,0,0,0.5);
        }
        .btn {
            width: 100%;
            background: #e94560;
            color: white;
            padding: 0.8rem;
            border-radius: 2rem;
            font-size: 1rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: 0.2s;
            margin-top: 0.5rem;
        }
        .btn:hover {
            background: #c5314b;
            transform: scale(1.02);
        }
        .back-link {
            display: block;
            text-align: center;
            margin-top: 1.5rem;
            color: #aaa;
            text-decoration: none;
            font-size: 0.85rem;
        }
        .back-link:hover {
            color: #e94560;
        }
        .error-msg {
            background: rgba(233,69,96,0.2);
            border: 1px solid #e94560;
            border-radius: 0.8rem;
            padding: 0.8rem;
            margin-bottom: 1rem;
            text-align: center;
            font-size: 0.85rem;
            color: #e94560;
        }
        .info-box {
            background: rgba(0,0,0,0.2);
            border-radius: 0.8rem;
            padding: 0.8rem;
            margin-bottom: 1.5rem;
            font-size: 0.8rem;
            color: #888;
            text-align: center;
        }
        footer {
            margin-top: 1.5rem;
            text-align: center;
            font-size: 0.7rem;
            color: #666;
        }
    </style>
</head>
<body>
<div class="gate-card">
    <h1>🔐 权限验证</h1>
    <div class="subtitle">请输入界面代码和密码以继续</div>

    <div id="errorMsg" class="error-msg" style="display: none;"></div>

    <div class="input-group">
        <label>📋 界面代码</label>
        <input type="text" id="pageCode" placeholder="例如：ADMIN_001" autocomplete="off">
    </div>

    <div class="input-group">
        <label>🔑 密码</label>
        <input type="password" id="password" placeholder="请输入密码" autocomplete="off">
    </div>

    <button class="btn" id="submitBtn">✓ 验证并进入</button>

    <a href="index.html" class="back-link">← 返回首页</a>

    <div class="info-box">
        ℹ️ 界面代码和密码请从目标页面的管理员处获取
    </div>

    <footer>© Arseeya. All Rights Reserved</footer>
</div>

<script>
    // ========== 页面代码与密码的对应关系（存储于代码中）==========
    // 格式：{ "界面代码": "密码" }
    // 你可以在这里添加任意多个受保护页面的代码和密码
    const ACCESS_MAP = {
        // 示例：管理员后台
        "ADMIN_001": "Arseeya2026",
        // 示例：内部测试页面
        "TEST_007": "test123",
        // 示例：草稿预览
        "DRAFT_888": "draft_pass",
        // ========== 在这里添加更多 ==========
        // "你的界面代码": "对应密码"
    };

    // 获取 URL 参数中的 target
    function getTarget() {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('target');
    }

    // 显示错误信息
    function showError(message) {
        const errorDiv = document.getElementById('errorMsg');
        errorDiv.textContent = message;
        errorDiv.style.display = 'block';
        setTimeout(() => {
            errorDiv.style.display = 'none';
        }, 3000);
    }

    // 验证并跳转
    function verifyAndRedirect() {
        const pageCode = document.getElementById('pageCode').value.trim();
        const password = document.getElementById('password').value.trim();
        const target = getTarget();

        if (!pageCode || !password) {
            showError('请填写界面代码和密码');
            return;
        }

        // 验证密码
        const correctPassword = ACCESS_MAP[pageCode];
        if (!correctPassword) {
            showError('界面代码不存在或密码错误');
            return;
        }

        if (password !== correctPassword) {
            showError('界面代码不存在或密码错误');
            return;
        }

        // 验证通过，跳转
        if (target) {
            // 如果有指定目标页面，跳转到该页面
            window.location.href = target;
        } else {
            // 没有指定目标，跳转到默认页面或显示成功
            showError('未指定目标页面，请联系管理员');
        }
    }

    // 在页面上显示目标信息（可选）
    function showTargetInfo() {
        const target = getTarget();
        if (target) {
            const infoBox = document.querySelector('.info-box');
            if (infoBox) {
                infoBox.innerHTML = `🎯 目标页面：${target}<br>ℹ️ 界面代码和密码请从目标页面的管理员处获取`;
            }
        }
    }

    // 绑定事件
    document.getElementById('submitBtn').addEventListener('click', verifyAndRedirect);
    document.getElementById('password').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            verifyAndRedirect();
        }
    });
    document.getElementById('pageCode').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            document.getElementById('password').focus();
        }
    });

    // 显示目标信息
    showTargetInfo();
</script>
</body>
</html>