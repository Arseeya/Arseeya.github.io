<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>完整条款 · Arseeya</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #0f0c1f, #1a1a2e);
            color: #eee;
            min-height: 100vh;
            padding: 1rem;
        }
        .container {
            max-width: 1000px;
            margin: 0 auto;
        }
        .back-home {
            display: inline-block;
            background: #e94560;
            color: white;
            padding: 0.5rem 1.2rem;
            border-radius: 2rem;
            text-decoration: none;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
        }
        .back-home:hover {
            background: #c5314b;
        }
        .terms-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(8px);
            border-radius: 1.5rem;
            padding: 2rem;
        }
        h1 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, #e94560, #667eea);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-align: center;
        }
        .last-updated {
            text-align: center;
            color: #aaa;
            font-size: 0.85rem;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .toc {
            background: rgba(0,0,0,0.2);
            border-radius: 1rem;
            padding: 1rem;
            margin-bottom: 1.5rem;
        }
        .toc h3 {
            font-size: 1rem;
            margin-bottom: 0.5rem;
            color: #e94560;
        }
        .toc-links {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        .toc-links a {
            color: #aaa;
            text-decoration: none;
            font-size: 0.8rem;
            padding: 0.2rem 0.6rem;
            background: rgba(255,255,255,0.05);
            border-radius: 1rem;
            transition: 0.2s;
        }
        .toc-links a:hover {
            background: #e94560;
            color: white;
        }
        .terms-content {
            line-height: 1.6;
        }
        .terms-content h2 {
            font-size: 1.2rem;
            color: #e94560;
            margin-top: 1.5rem;
            margin-bottom: 0.5rem;
            border-left: 3px solid #e94560;
            padding-left: 0.8rem;
        }
        .terms-content h3 {
            font-size: 1rem;
            color: #ddd;
            margin-top: 1rem;
            margin-bottom: 0.3rem;
            padding-left: 0.5rem;
        }
        .terms-content p, .terms-content li {
            font-size: 0.85rem;
            line-height: 1.5;
            color: #ccc;
            margin-bottom: 0.5rem;
        }
        .terms-content ul, .terms-content ol {
            margin-left: 1.5rem;
            margin-bottom: 0.8rem;
        }
        .terms-content strong {
            color: #e94560;
        }
        footer {
            margin-top: 2rem;
            text-align: center;
            font-size: 0.75rem;
            color: #666;
            padding-top: 1rem;
            border-top: 1px solid rgba(255,255,255,0.05);
        }
        @media (max-width: 640px) {
            .terms-card {
                padding: 1rem;
            }
            h1 {
                font-size: 1.4rem;
            }
        }
    </style>
</head>
