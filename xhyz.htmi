<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>熊海云档案</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #0f0c1f, #1a1a2e);
            color: #eee;
            min-height: 100vh;
            padding: 1rem;
        }
        .container {
            max-width: 1000px;
            margin: 0 auto;
        }
        .back-home {
            display: inline-block;
            background: #e94560;
            color: white;
            padding: 0.5rem 1.2rem;
            border-radius: 2rem;
            text-decoration: none;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
        }
        .back-home:hover {
            background: #c5314b;
        }
        .profile-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(10px);
            border-radius: 2rem;
            padding: 2rem;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .profile-header {
            display: flex;
            gap: 2rem;
            flex-wrap: wrap;
            align-items: center;
            margin-bottom: 2rem;
        }
        .avatar {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            background: linear-gradient(135deg, #e94560, #667eea);
            padding: 3px;
        }
        .avatar img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
        }
        .info h1 {
            font-size: 2rem;
            background: linear-gradient(135deg, #e94560, #667eea);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 0.5rem;
        }
        .info p {
            color: #aaa;
            margin-bottom: 0.3rem;
        }
        .badge {
            display: inline-block;
            background: rgba(233,69,96,0.2);
            border: 1px solid #e94560;
            border-radius: 2rem;
            padding: 0.2rem 0.8rem;
            font-size: 0.8rem;
            color: #e94560;
        }
        .section-title {
            font-size: 1.3rem;
            margin: 1.5rem 0 1rem;
            color: #e94560;
            border-left: 3px solid #e94560;
            padding-left: 0.8rem;
        }
        .intro-text {
            background: rgba(0,0,0,0.3);
            border-radius: 1rem;
            padding: 1.2rem;
            line-height: 1.8;
            margin-bottom: 1rem;
        }
        .pdf-list {
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
        }
        .pdf-item {
            background: rgba(255,255,255,0.05);
            border-radius: 1rem;
            padding: 1rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            transition: 0.2s;
            text-decoration: none;
            color: #eee;
        }
        .pdf-item:hover {
            background: rgba(255,255,255,0.12);
            transform: translateX(4px);
        }
        .pdf-icon {
            font-size: 2rem;
        }
        .pdf-info {
            flex: 1;
        }
        .pdf-name {
            font-weight: bold;
            margin-bottom: 0.2rem;
        }
        .pdf-size {
            font-size: 0.75rem;
            color: #888;
        }
        .open-btn {
            background: #e94560;
            padding: 0.4rem 1rem;
            border-radius: 2rem;
            font-size: 0.8rem;
        }
        footer {
            margin-top: 2rem;
            text-align: center;
            font-size: 0.75rem;
            color: #666;
            padding-top: 1rem;
            border-top: 1px solid rgba(255,255,255,0.05);
        }
        @media (max-width: 640px) {
            .profile-header {
                flex-direction: column;
                text-align: center;
            }
            .profile-card {
                padding: 1rem;
            }
        }
    </style>
</head>
<body>
<div class="container">
    <a href="index.html" class="back-home">← 返回首页</a>
    
    <div class="profile-card">
        <div class="profile-header">
            <div class="avatar">
                <img src="xhyz.jpg" alt="熊海云" onerror="this.src='data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22150%22%20height%3D%22150%22%3E%3Crect%20width%3D%22150%22%20height%3D%22150%22%20fill%3D%22%23333%22%2F%3E%3Ctext%20x%3D%2275%22%20y%3D%2285%22%20text-anchor%3D%22middle%22%20fill%3D%22%23aaa%22%3E📷%3C%2Ftext%3E%3C%2Fsvg%3E'">
            </div>
            <div class="info">
                <h1>🐻 熊海云</h1>
                <p>男 · 2008年生人</p>
                <p><span class="badge">好友档案</span></p>
            </div>
        </div>
        
        <div class="section-title">📝 关于他</div>
        <div class="intro-text">
            <p>熊海云，2008年生，作者 Arseeya 的好友。</p>
            <p style="margin-top:0.5rem;">🌟 此页面纯粹做着好玩，记录友谊～</p>
        </div>
        
        <div class="section-title">📄 文档资料</div>
        <div id="pdfList" class="pdf-list">
            <div style="text-align:center; color:#aaa;">加载中...</div>
        </div>
    </div>
    
    <footer>© Arseeya. All Rights Reserved | 好友档案 · 做着好玩</footer>
</div>

<script>
    // PDF 文件列表（存放在 downloads/pdf/ 目录下）
    // 你可以在这里添加任意多个 PDF 文件
    const pdfFiles = [
        { name: "关于我校高二（6）班熊海云同学基本情况的通报", file: "xhy.pdf", size: "约 2260 KB" },
        // 添加更多 PDF：
        // { name: "文档名称", file: "文件名.pdf", size: "约 X MB" }
    ];
    
    function renderPdfList() {
        const container = document.getElementById('pdfList');
        if (!pdfFiles.length) {
            container.innerHTML = '<div style="text-align:center; padding:2rem; color:#888;">📭 暂无 PDF 文件</div>';
            return;
        }
        
        container.innerHTML = pdfFiles.map(pdf => `
            <a href="downloads/pdf/${pdf.file}" class="pdf-item" target="_blank">
                <div class="pdf-icon">📄</div>
                <div class="pdf-info">
                    <div class="pdf-name">${pdf.name}</div>
                    <div class="pdf-size">${pdf.size}</div>
                </div>
                <div class="open-btn">打开 →</div>
            </a>
        `).join('');
    }
    
    renderPdfList();
</script>
</body>
</html>